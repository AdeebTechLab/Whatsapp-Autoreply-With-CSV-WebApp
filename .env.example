# Server
PORT=3000

# Bot behavior
BOT_NAME=Adeeb ChatBoot
AUTO_REPLY_ENABLED=true
IGNORE_GROUPS=true
MIN_MATCH_SCORE=0.45
BOT_REPLY_DELAY_MS=800
FALLBACK_COOLDOWN_SECONDS=60
CONTACT_NAME_FALLBACK=Friend

# Business hours are optional. Keep false for demo.
BUSINESS_HOURS_ENABLED=false
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=18
TIMEZONE=Asia/Karachi

# Fallback message when no CSV option is matched
FALLBACK_REPLY=I am Adeeb ChatBoot 💬 Sorry, I could not find this option. Please type Main Menu to see available options.

# FAQ source:
# csv_file = reads the uploaded CSV file from config/auto-reply-sheet1.csv
# google_sheet = reads live Sheet1 from Google Sheets as CSV
# local = reads config/faqs.json
FAQ_SOURCE=csv_file
LOCAL_CSV_PATH=./config/auto-reply-sheet1.csv
CSV_REFRESH_SECONDS=15
SHEET_REFRESH_SECONDS=15

# Hide visible quotation marks in WhatsApp replies, e.g. "Main Menu" becomes Main Menu.
# It also removes paired labels like ''Tech'' but keeps normal apostrophes like You're.
STRIP_RESPONSE_QUOTES=true

# Optional Google Sheet live source. To use it, set FAQ_SOURCE=google_sheet.
GOOGLE_SHEET_ID=1hCz8S0JFTFEESV7IRejWZipyB4isVDh7GKDRPH010dQ
GOOGLE_SHEET_NAME=Sheet1
# If you know Sheet1 gid, you may use GOOGLE_SHEET_GID instead of GOOGLE_SHEET_NAME.
# GOOGLE_SHEET_GID=0
# Or paste a published CSV/export URL directly:
# GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_ID/gviz/tq?tqx=out:csv&sheet=Sheet1

# WhatsApp session storage. Keep this folder persistent on VPS.
WHATSAPP_CLIENT_ID=adeeb-chatboot
WHATSAPP_AUTH_PATH=./data/whatsapp-session

# Browser path is optional. Project auto-detects Chrome/Edge on Windows.
# On Linux VPS, install Chromium/Chrome and set this if auto-detect fails.
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
